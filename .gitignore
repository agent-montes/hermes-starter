!templates/Hermes Recovery/
!templates/Hermes Recovery/**

# Local dev
.DS_Store
.venv/
.venv-*/
node_modules/
__pycache__/
.pytest_cache/

# Optional app dependency/build outputs
apps/*/node_modules/
apps/*/dist/
apps/*/dist-electron/
apps/*/release/
apps/*/.venv/
apps/*/.venv-*/
