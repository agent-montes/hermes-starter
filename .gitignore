# Secrets and auth
.env
.env.*
!.env.example
!*.env.example
auth.json
*.pem
*.key
*.p12
*.pfx
*.mobileconfig

# Runtime state
sessions/
state/
logs/
cache/
request-dumps/
gateway-state/
allowed-users*
*.sqlite
*.sqlite3
*.db

# Backups/recovery archives
recovery/
backups/
*.tar
*.tar.gz
*.zip

