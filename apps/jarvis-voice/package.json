{
  "name": "jarvis-voice",
  "productName": "JARVIS",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "A minimal local realtime voice companion.",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && node scripts/run-electron.mjs\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "npm run build && node scripts/run-electron.mjs --prod",
    "start:prod": "node scripts/run-electron.mjs --prod",
    "package:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win --dir",
    "dist:win": "npm run build && electron-builder --win",
    "electron": "node scripts/run-electron.mjs",
    "phone": "node scripts/phone-bridge.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "wait-on": "latest"
  },
  "build": {
    "appId": "app.jarvis.voice",
    "productName": "JARVIS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts/openwakeword-listener.py",
        "to": "scripts/openwakeword-listener.py"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "extendInfo": {
        "CFBundleDisplayName": "J.A.R.V.I.S."
      },
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
