GEMINI_API_KEY=<GEMINI_API_KEY_PLACEHOLDER>

# Optional overrides
JARVIS_USER_NAME=there
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Leda
HERMES_API_URL=http://127.0.0.1:8642
API_SERVER_KEY=<LOCAL_HERMES_API_KEY>

# Local wake word: openWakeWord runs fully on this machine, with no account,
# API key, cloud runtime, or extra billing. Requires the ignored local Python
# venv created by the setup steps. Default is privacy-first/off; set true
# only when you intentionally want always-listening wake detection.
OPENWAKEWORD_WAKE_ENABLED=false
OPENWAKEWORD_MODEL=hey_jarvis
OPENWAKEWORD_THRESHOLD=0.35
OPENWAKEWORD_VAD_THRESHOLD=0
# Optional for packaged installs that use a venv outside this repo:
# OPENWAKEWORD_PYTHON=/absolute/path/to/.venv-openwakeword/bin/python
# OPENWAKEWORD_SCRIPT=/absolute/path/to/scripts/openwakeword-listener.py

# Optional LAN phone bridge. Leave host unset to bind to the first LAN IPv4;
# set to 127.0.0.1 to keep it local-only. The token is generated into ignored
# .env by `npm run phone` if not already set.
# JARVIS_PHONE_HOST=127.0.0.1
JARVIS_PHONE_PORT=8787
# JARVIS_PHONE_TOKEN=<GENERATED_OR_SET_LOCALLY>

# Optional: full path to the Hermes binary if your packaged GUI app cannot find
# it on PATH. Usually not required when Hermes gateway is already running.
# macOS/Linux example:
# HERMES_BIN=/path/to/hermes
# Windows example:
# HERMES_BIN=C:\\Users\\you\\AppData\\Local\\Programs\\hermes\\hermes.exe
