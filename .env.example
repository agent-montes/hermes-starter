# Placeholder environment file. Never commit a real environment file.
HERMES_HOME=<YOUR_HERMES_HOME>
PRIMARY_PROVIDER=<PRIMARY_PROVIDER>
PRIMARY_MODEL=<PRIMARY_MODEL>

# Provider credentials belong in your private secret store.
# MODEL_PROVIDER_API_KEY=<PLACEHOLDER_ONLY>

# Messaging credentials belong outside this public repo.
# MESSAGING_PLATFORM_TOKEN=<PLACEHOLDER_ONLY>

# Optional realtime voice shell placeholders. Values belong in private Secrets
# and local ignored app environment files, never in this public starter.
# VOICE_PROVIDER_API_KEY=<PLACEHOLDER_ONLY>
# HERMES_API_URL=http://127.0.0.1:<PORT_PLACEHOLDER>
# HERMES_API_SERVER_KEY=<PLACEHOLDER_ONLY>
